<%- include('../layout', { title, user, body: `
  <div class="row">
    <div class="col-md-6">
      <h3>${mode === 'create' ? 'Create New Admin' : 'Edit Admin'}</h3>
      ${error ? '<div class="alert alert-danger">' + error + '</div>' : ''}
      <form method="post" action="/admin/users" class="mt-3">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <div class="mb-3">
          <label class="form-label">Username</label>
          <input 
            type="text" 
            name="username" 
            class="form-control" 
            value="${(admin && admin.username) || ''}"
            ${mode === 'edit' ? 'readonly' : 'required'}
            placeholder="Enter username"
          />
        </div>
        <div class="mb-3">
          <label class="form-label">Email</label>
          <input 
            type="email" 
            name="email" 
            class="form-control" 
            value="${(admin && admin.email) || ''}"
            required
            placeholder="Enter email address"
          />
        </div>
        <div class="mb-3">
          <label class="form-label">Password</label>
          <input 
            type="password" 
            name="password" 
            class="form-control" 
            ${mode === 'create' ? 'required' : ''}
            placeholder="${mode === 'create' ? 'Enter password' : 'Leave blank to keep current password'}"
          />
          <small class="form-text text-muted">Minimum 6 characters</small>
        </div>
        <div class="mb-3">
          <label class="form-label">Role</label>
          <select name="role" class="form-select" required>
            <option value="">Select a role</option>
            <option value="SUPER_ADMIN" ${(admin && admin.role) === 'SUPER_ADMIN' ? 'selected' : ''}>Super Admin</option>
            <option value="EDITOR" ${(admin && admin.role) === 'EDITOR' ? 'selected' : ''}>Editor</option>
            <option value="MODERATOR" ${(admin && admin.role) === 'MODERATOR' ? 'selected' : ''}>Moderator</option>
          </select>
        </div>
        <div class="mb-3">
          <button type="submit" class="btn btn-primary">
            ${mode === 'create' ? 'Create Admin' : 'Update Admin'}
          </button>
          <a href="/admin/users" class="btn btn-secondary">Cancel</a>
        </div>
      </form>
    </div>
  </div>
` }) %>
