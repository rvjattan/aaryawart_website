<% const { csrfToken } = locals; %>
<%- include('../layout', { title, user, body: `
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="heading-no-margin">User Management</h3>
    <a href="/admin/users/new" class="btn btn-primary">
      <i class="bi bi-plus-circle"></i> Create New Admin
    </a>
  </div>
  <table class="table table-striped table-sm">
    <thead>
      <tr>
        <th>Username</th>
        <th>Email</th>
        <th>Role</th>
        <th>Created</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      ${admins.map(a => `
        <tr>
          <td>${a.username}</td>
          <td>${a.email}</td>
          <td>${a.role}</td>
          <td>${new Date(a.created_at).toLocaleDateString()}</td>
          <td>
            <div class="d-flex gap-1">
              <form method="post" action="/admin/users/${a.id}/role" class="d-flex gap-1">
                <input type="hidden" name="_csrf" value="${csrfToken}" />
                <select name="role" class="form-select form-select-sm">
                  <option value="SUPER_ADMIN" ${a.role === 'SUPER_ADMIN' ? 'selected' : ''}>Super Admin</option>
                  <option value="EDITOR" ${a.role === 'EDITOR' ? 'selected' : ''}>Editor</option>
                  <option value="MODERATOR" ${a.role === 'MODERATOR' ? 'selected' : ''}>Moderator</option>
                </select>
                <button class="btn btn-sm btn-outline-primary">Update</button>
              </form>
              <form method="post" action="/admin/users/${a.id}/delete" class="form-inline-display" onsubmit="return confirm('Are you sure you want to delete this admin?');">
                <input type="hidden" name="_csrf" value="${csrfToken}" />
                <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
              </form>
            </div>
          </td>
        </tr>
      `).join('')}
    </tbody>
  </table>
` }) %>

