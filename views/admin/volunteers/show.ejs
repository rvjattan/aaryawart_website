<%- include('../layout', { title, user, body: `
  <h3>Volunteer Detail</h3>
  <dl class="row">
    <dt class="col-sm-3">Name</dt>
    <dd class="col-sm-9">${volunteer.name}</dd>

    <dt class="col-sm-3">Email</dt>
    <dd class="col-sm-9">${volunteer.email}</dd>

    <dt class="col-sm-3">Phone</dt>
    <dd class="col-sm-9">${volunteer.phone}</dd>

    <dt class="col-sm-3">Address</dt>
    <dd class="col-sm-9">${volunteer.address || ''}</dd>

    <dt class="col-sm-3">State</dt>
    <dd class="col-sm-9">${volunteer.state || ''}</dd>

    <dt class="col-sm-3">City</dt>
    <dd class="col-sm-9">${volunteer.city || ''}</dd>

    <dt class="col-sm-3">Skills</dt>
    <dd class="col-sm-9">${volunteer.skills || ''}</dd>

    <dt class="col-sm-3">Availability</dt>
    <dd class="col-sm-9">${volunteer.availability || ''}</dd>

    <dt class="col-sm-3">Registered</dt>
    <dd class="col-sm-9">${new Date(volunteer.registered_date).toLocaleString()}</dd>
  </dl>

  <form method="post" action="/admin/volunteers/${volunteer.id}/delete" onsubmit="return confirm('Delete this volunteer?');">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <button class="btn btn-danger">Delete</button>
    <a href="/admin/volunteers" class="btn btn-secondary">Back</a>
  </form>
` }) %>

