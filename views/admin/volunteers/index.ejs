<%- include('../layout', { title, user, body: `
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h3>Volunteers</h3>
    <div>
      <a href="/admin/volunteers/export/csv${filters.state || filters.city || filters.search ? '?' + new URLSearchParams(filters).toString() : ''}" class="btn btn-sm btn-outline-success me-2"><i class="bi bi-file-earmark-spreadsheet"></i> Export CSV</a>
      <a href="/admin/volunteers/export/excel${filters.state || filters.city || filters.search ? '?' + new URLSearchParams(filters).toString() : ''}" class="btn btn-sm btn-outline-primary me-2"><i class="bi bi-file-earmark-excel"></i> Export Excel</a>
    </div>
  </div>

  <form class="d-flex gap-2 mb-3" method="get">
    <input type="text" name="search" class="form-control form-control-sm" placeholder="Search name/email" value="${filters.search || ''}" />
    <input type="text" name="state" class="form-control form-control-sm" placeholder="State" value="${filters.state || ''}" />
    <input type="text" name="city" class="form-control form-control-sm" placeholder="City" value="${filters.city || ''}" />
    <button class="btn btn-sm btn-outline-primary" type="submit">Filter</button>
  </form>

  <table class="table table-striped table-sm">
    <thead>
      <tr>
        <th>Name</th>
        <th>Email</th>
        <th>Phone</th>
        <th>State</th>
        <th>City</th>
        <th>Registered</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      ${data.map(v => `
        <tr>
          <td>${v.name}</td>
          <td>${v.email}</td>
          <td>${v.phone}</td>
          <td>${v.state || ''}</td>
          <td>${v.city || ''}</td>
          <td>${new Date(v.registered_date).toLocaleDateString()}</td>
          <td class="text-end">
            <a href="/admin/volunteers/${v.id}" class="btn btn-sm btn-outline-secondary">View</a>
            <button type="button" class="btn btn-sm btn-outline-danger" onclick="deleteVolunteer(${v.id}, '${v.name.replace(/'/g, "\\'")}')">Delete</button>
          </td>
        </tr>
      `).join('')}
    </tbody>
  </table>

  <nav>
    <ul class="pagination">
      ${Array.from({ length: Math.ceil(total / limit) || 1 }).map((_, i) => {
        const p = i + 1;
        const active = p === page ? 'active' : '';
        const params = new URLSearchParams({ ...filters, page: String(p) }).toString();
        return `<li class="page-item ${active}"><a class="page-link" href="?${params}">${p}</a></li>`;
      }).join('')}
    </ul>
  </nav>
` }) %>

