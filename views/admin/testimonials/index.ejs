<%- include('../layout', { title, user, body: `
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h3>Testimonials</h3>
  </div>

  <div class="mb-3">
    <a href="/admin/testimonials" class="btn btn-sm ${filters.status === null || filters.status === undefined ? 'btn-primary' : 'btn-outline-primary'}">All</a>
    <a href="/admin/testimonials?status=pending" class="btn btn-sm ${filters.status === 'pending' ? 'btn-warning' : 'btn-outline-warning'}">Pending</a>
    <a href="/admin/testimonials?status=approved" class="btn btn-sm ${filters.status === 'approved' ? 'btn-success' : 'btn-outline-success'}">Approved</a>
  </div>

  <table class="table table-striped table-sm">
    <thead>
      <tr>
        <th>Name</th>
        <th>Email</th>
        <th>Message</th>
        <th>Status</th>
        <th>Submitted</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      ${data.map(t => \`
        <tr>
          <td>\${t.name}</td>
          <td>\${t.email}</td>
          <td>\${t.message.substring(0, 50)}...</td>
          <td>
            \${t.is_approved ? '<span class="badge bg-success">Approved</span>' : '<span class="badge bg-warning">Pending</span>'}
          </td>
          <td>\${new Date(t.submitted_at).toLocaleDateString()}</td>
          <td class="text-end">
            <div class="btn-group btn-group-sm" role="group">
              \${!t.is_approved ? \`
                <form method="post" action="/admin/testimonials/\${t.id}/approve?status=\${filters.status || ''}" style="display:inline;">
                  <button type="submit" class="btn btn-outline-success" title="Approve"><i class="bi bi-check"></i></button>
                </form>
              \` : ''}
              \${t.is_approved ? \`
                <form method="post" action="/admin/testimonials/\${t.id}/reject?status=\${filters.status || ''}" style="display:inline;">
                  <button type="submit" class="btn btn-outline-warning" title="Reject"><i class="bi bi-x"></i></button>
                </form>
              \` : ''}
              <form method="post" action="/admin/testimonials/\${t.id}/delete?status=\${filters.status || ''}" style="display:inline;" onsubmit="return confirm('Delete this testimonial?');">
                <button type="submit" class="btn btn-outline-danger" title="Delete"><i class="bi bi-trash"></i></button>
              </form>
            </div>
          </td>
        </tr>
      \`).join('')}
    </tbody>
  </table>

  \${data.length === 0 ? '<p class="text-muted">No testimonials found.</p>' : ''}

  <nav>
    <ul class="pagination">
      \${Array.from({ length: pages || 1 }).map((_, i) => {
        const p = i + 1;
        const active = p === parseInt(page) ? 'active' : '';
        const statusParam = filters.status ? '&status=' + filters.status : '';
        return \`<li class="page-item \${active}"><a class="page-link" href="?page=\${p}\${statusParam}">\${p}</a></li>\`;
      }).join('')}
    </ul>
  </nav>
` }) %>
