<%- include('../layout', { title, user, body: `
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="heading-no-margin">Testimonials Management</h3>
  </div>

<div class="mb-3">
    <a href="/admin/testimonials" class="btn btn-sm ${!filters.status ? 'btn-primary' : 'btn-outline-primary'}">All</a>
    <a href="/admin/testimonials?status=pending" class="btn btn-sm ${filters.status === 'pending' ? 'btn-warning' : 'btn-outline-warning'}">Pending (${total ? data.filter(t => !t.is_approved).length : 0})</a>
    <a href="/admin/testimonials?status=approved" class="btn btn-sm ${filters.status === 'approved' ? 'btn-success' : 'btn-outline-success'}">Approved (${total ? data.filter(t => t.is_approved).length : 0})</a>
  </div>

  ${total === 0 ? '<div class="alert alert-info">No testimonials yet. Submitted testimonials will appear here for approval.</div>' : ''}

  <table class="table table-striped table-sm">
    <thead>
      <tr>
        <th>Name</th>
        <th>Email</th>
        <th>Message</th>
        <th>Status</th>
        <th>Date</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      ${(data && data.length > 0) ? data.map(t => {
        let html = '<tr><td><strong>' + (t.name || '(Unknown)') + '</strong></td>';
        html += '<td><small>' + (t.email || '(No email)') + '</small></td>';
        html += '<td><small>' + (t.message ? t.message.substring(0, 50) + (t.message.length > 50 ? '...' : '') : '(Empty)') + '</small></td>';
        html += '<td>' + (t.is_approved ? '<span class="badge bg-success">Approved</span>' : '<span class="badge bg-warning text-dark">Pending</span>') + '</td>';
        html += '<td><small>' + (t.submitted_at ? new Date(t.submitted_at).toLocaleDateString() : 'N/A') + '</small></td>';
        html += '<td style="white-space: nowrap;">';
        if (!t.is_approved) {
          html += '<button type="button" class="btn btn-sm btn-success" data-action="approve" data-id="' + t.id + '" data-status="' + (filters.status || 'pending') + '">Approve</button> ';
        }
        if (t.is_approved) {
          html += '<button type="button" class="btn btn-sm btn-warning" data-action="reject" data-id="' + t.id + '" data-status="' + (filters.status || 'approved') + '">Reject</button> ';
        }
        html += '<button type="button" class="btn btn-sm btn-danger" data-action="delete" data-id="' + t.id + '" data-status="' + (filters.status || 'pending') + '">Delete</button>';
        html += '</td></tr>';
        return html;
      }).join('') : '<tr><td colspan="6" class="text-center text-muted py-4">No testimonials found</td></tr>'}
    </tbody>
  </table>

  ${pages && pages > 1 ? (() => {
    let html = '<nav><ul class="pagination">';
    for (let i = 1; i <= pages; i++) {
      const statusParam = filters.status ? '&status=' + filters.status : '';
      html += '<li class="page-item ' + (i === parseInt(page) ? 'active' : '') + '"><a class="page-link" href="?page=' + i + statusParam + '">' + i + '</a></li>';
    }
    html += '</ul></nav>';
    return html;
  })() : ''}

  <script>
    document.querySelectorAll('[data-action]').forEach(btn => {
      btn.addEventListener('click', async (e) => {
        const action = e.target.dataset.action;
        const id = e.target.dataset.id;
        const statusParam = e.target.dataset.status ? '?status=' + e.target.dataset.status : '';
        
        if (action === 'delete' && !confirm('Are you sure you want to delete this testimonial?')) {
          return;
        }
        
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = '/admin/testimonials/' + id + '/' + action + statusParam;
        document.body.appendChild(form);
        form.submit();
      });
    });
  </script>
` }) %>
