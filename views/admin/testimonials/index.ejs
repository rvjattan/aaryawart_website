<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %> - Admin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container-fluid">
      <a class="navbar-brand" href="/admin/dashboard">Charity Admin</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav me-auto">
          <li class="nav-item"><a class="nav-link" href="/admin/dashboard">Dashboard</a></li>
          <li class="nav-item"><a class="nav-link" href="/admin/volunteers">Volunteers</a></li>
          <li class="nav-item"><a class="nav-link" href="/admin/blogs">Blogs</a></li>
          <li class="nav-item"><a class="nav-link" href="/admin/media">Media</a></li>
          <li class="nav-item"><a class="nav-link" href="/admin/testimonials">Testimonials</a></li>
          <li class="nav-item"><a class="nav-link" href="/admin/users">Users</a></li>
          <li class="nav-item"><a class="nav-link" href="/admin/settings">Settings</a></li>
        </ul>
        <span class="navbar-text me-3"><i class="bi bi-person-circle"></i> <%= user && user.username %></span>
        <a class="btn btn-outline-light btn-sm" href="/admin/logout">Logout</a>
      </div>
    </div>
  </nav>
  <main class="container my-4 px-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h3 class="heading-no-margin">Testimonials Management</h3>
    </div>

    <div class="mb-3">
      <a href="/admin/testimonials" class="btn btn-sm <%= !filters.status ? 'btn-primary' : 'btn-outline-primary' %>">
        All (<%= total %>)
      </a>
      <a href="/admin/testimonials?status=pending" class="btn btn-sm <%= filters.status === 'pending' ? 'btn-warning' : 'btn-outline-warning' %>">
        Pending (<%= data.filter(t => !t.is_approved).length %>)
      </a>
      <a href="/admin/testimonials?status=approved" class="btn btn-sm <%= filters.status === 'approved' ? 'btn-success' : 'btn-outline-success' %>">
        Approved (<%= data.filter(t => t.is_approved).length %>)
      </a>
    </div>

    <% if (total === 0) { %>
      <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No testimonials yet. Submitted testimonials will appear here for approval.
      </div>
    <% } %>

    <div class="table-responsive">
      <table class="table table-striped table-sm">
        <thead>
          <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Message</th>
            <th>Status</th>
            <th>Date</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if (data && data.length > 0) { %>
            <% data.forEach(t => { %>
              <tr>
                <td><strong><%= t.name || '(Unknown)' %></strong></td>
                <td><small><%= t.email || '(No email)' %></small></td>
                <td><small><%= (t.message ? t.message.substring(0, 50) + (t.message.length > 50 ? '...' : '') : '(Empty)') %></small></td>
                <td>
                  <% if (t.is_approved) { %>
                    <span class="badge bg-success">Approved</span>
                  <% } else { %>
                    <span class="badge bg-warning text-dark">Pending</span>
                  <% } %>
                </td>
                <td><small><%= t.submitted_at ? new Date(t.submitted_at).toLocaleDateString() : 'N/A' %></small></td>
                <td style="white-space: nowrap;">
                  <% if (!t.is_approved) { %>
                    <form method="post" action="/admin/testimonials/<%= t.id %>/approve<%= filters.status ? '?status=' + filters.status : '' %>" style="display: inline;">
                      <input type="hidden" name="_csrf" value="${csrfToken}" />
                      <button type="submit" class="btn btn-sm btn-success">Approve</button>
                    </form>
                  <% } %>
                  <% if (t.is_approved) { %>
                    <form method="post" action="/admin/testimonials/<%= t.id %>/reject<%= filters.status ? '?status=' + filters.status : '' %>" style="display: inline;">
                      <input type="hidden" name="_csrf" value="${csrfToken}" />
                      <button type="submit" class="btn btn-sm btn-warning">Reject</button>
                    </form>
                  <% } %>
                  <form method="post" action="/admin/testimonials/<%= t.id %>/delete<%= filters.status ? '?status=' + filters.status : '' %>" style="display: inline;" onsubmit="return confirm('Are you sure?');">
                    <input type="hidden" name="_csrf" value="${csrfToken}" />
                    <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                  </form>
                </td>
              </tr>
            <% }); %>
          <% } else { %>
            <tr>
              <td colspan="6" class="text-center text-muted py-4">
                <p class="mb-1">No testimonials found</p>
                <small>Submitted testimonials will appear here</small>
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>

    <% if (pages && pages > 1) { %>
      <nav>
        <ul class="pagination">
          <% for (let i = 1; i <= pages; i++) { %>
            <% const statusParam = filters.status ? '&status=' + filters.status : ''; %>
            <li class="page-item <%= i === parseInt(page) ? 'active' : '' %>">
              <a class="page-link" href="?page=<%= i %><%= statusParam %>"><%= i %></a>
            </li>
          <% } %>
        </ul>
      </nav>
    <% } %>
  </main>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

