<%- include('../layout', { title, user, body: `
  <h3>Testimonials Management</h3>
  
  <div class="mb-3">
    <a href="/admin/testimonials" class="btn btn-sm ${!filters.status ? 'btn-primary' : 'btn-outline-primary'}">All</a>
    <a href="/admin/testimonials?status=pending" class="btn btn-sm ${filters.status === 'pending' ? 'btn-warning' : 'btn-outline-warning'}">Pending</a>
    <a href="/admin/testimonials?status=approved" class="btn btn-sm ${filters.status === 'approved' ? 'btn-success' : 'btn-outline-success'}">Approved</a>
  </div>

  <table class="table table-striped">
    <thead>
      <tr>
        <th>Name</th>
        <th>Email</th>
        <th>Message</th>
        <th>Status</th>
        <th>Date</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      ${(data && data.length > 0) ? data.map(t => {
        let html = '<tr><td>' + t.name + '</td>';
        html += '<td>' + t.email + '</td>';
        html += '<td>' + t.message.substring(0, 40) + '...</td>';
        html += '<td>' + (t.is_approved ? '<span class="badge bg-success">Approved</span>' : '<span class="badge bg-warning">Pending</span>') + '</td>';
        html += '<td>' + new Date(t.submitted_at).toLocaleDateString() + '</td>';
        html += '<td>';
        if (!t.is_approved) {
          html += '<form method="post" action="/admin/testimonials/' + t.id + '/approve' + (filters.status ? '?status=' + filters.status : '') + '" style="display:inline;"><button class="btn btn-sm btn-success" type="submit">Approve</button></form> ';
        }
        if (t.is_approved) {
          html += '<form method="post" action="/admin/testimonials/' + t.id + '/reject' + (filters.status ? '?status=' + filters.status : '') + '" style="display:inline;"><button class="btn btn-sm btn-warning" type="submit">Reject</button></form> ';
        }
        html += '<form method="post" action="/admin/testimonials/' + t.id + '/delete' + (filters.status ? '?status=' + filters.status : '') + '" style="display:inline;" onsubmit="return true;"><button class="btn btn-sm btn-danger" type="submit">Delete</button></form>';
        html += '</td></tr>';
        return html;
      }).join('') : '<tr><td colspan="6" class="text-center text-muted">No testimonials found</td></tr>'}
    </tbody>
  </table>

  ${pages && pages > 1 ? (() => {
    let html = '<nav><ul class="pagination">';
    for (let i = 1; i <= pages; i++) {
      const statusParam = filters.status ? '&status=' + filters.status : '';
      html += '<li class="page-item ' + (i === parseInt(page) ? 'active' : '') + '"><a class="page-link" href="?page=' + i + statusParam + '">' + i + '</a></li>';
    }
    html += '</ul></nav>';
    return html;
  })() : ''}
` }) %>
