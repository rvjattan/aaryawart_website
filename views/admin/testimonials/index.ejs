<%- include('../layout', { title, user, body: `
  <h3>Testimonials Management</h3>
  
  <div class="mb-3 d-flex gap-2">
    <a href="/admin/testimonials" class="btn btn-sm ${!filters.status ? 'btn-primary' : 'btn-outline-primary'}">All</a>
    <a href="/admin/testimonials?status=pending" class="btn btn-sm ${filters.status === 'pending' ? 'btn-warning' : 'btn-outline-warning'}">Pending</a>
    <a href="/admin/testimonials?status=approved" class="btn btn-sm ${filters.status === 'approved' ? 'btn-success' : 'btn-outline-success'}">Approved</a>
  </div>

  <table class="table table-striped table-sm">
    <thead>
      <tr>
        <th>Name</th>
        <th>Email</th>
        <th>Message</th>
        <th>Status</th>
        <th>Submitted</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      ${data && data.length > 0 ? data.map(t => {
        const approveAction = '/admin/testimonials/' + t.id + '/approve' + (filters.status ? '?status=' + filters.status : '');
        const rejectAction = '/admin/testimonials/' + t.id + '/reject' + (filters.status ? '?status=' + filters.status : '');
        const deleteAction = '/admin/testimonials/' + t.id + '/delete' + (filters.status ? '?status=' + filters.status : '');
        return '<tr>' +
          '<td>' + t.name + '</td>' +
          '<td>' + t.email + '</td>' +
          '<td>' + t.message.substring(0, 50) + '...</td>' +
          '<td>' + (t.is_approved ? '<span class="badge bg-success">Approved</span>' : '<span class="badge bg-warning">Pending</span>') + '</td>' +
          '<td>' + new Date(t.submitted_at).toLocaleDateString() + '</td>' +
          '<td class="text-end">' +
            (!t.is_approved ? '<form method="post" action="' + approveAction + '" style="display:inline;"><button type="submit" class="btn btn-sm btn-outline-success" title="Approve"><i class="bi bi-check"></i></button></form>' : '') +
            (t.is_approved ? '<form method="post" action="' + rejectAction + '" style="display:inline;"><button type="submit" class="btn btn-sm btn-outline-warning" title="Reject"><i class="bi bi-x"></i></button></form>' : '') +
            '<form method="post" action="' + deleteAction + '" style="display:inline;" onsubmit="return confirm(\'Delete this testimonial?\');"><button type="submit" class="btn btn-sm btn-outline-danger" title="Delete"><i class="bi bi-trash"></i></button></form>' +
          '</td>' +
        '</tr>';
      }).join('') : '<tr><td colspan="6" class="text-center text-muted">No testimonials found.</td></tr>'}
    </tbody>
  </table>

  ${pages > 1 ? '<nav><ul class="pagination">' + Array.from({length: pages}).map((_, i) => {
    const pageNum = i + 1;
    const statusParam = filters.status ? '&status=' + filters.status : '';
    return '<li class="page-item ' + (pageNum === parseInt(page) ? 'active' : '') + '"><a class="page-link" href="?page=' + pageNum + statusParam + '">' + pageNum + '</a></li>';
  }).join('') + '</ul></nav>' : ''}
` }) %>
