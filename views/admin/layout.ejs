<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> - Admin Panel</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"
    />
  </head>
  <body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
      <div class="container-fluid">
        <a class="navbar-brand" href="/admin/dashboard">Charity Admin</a>
        <button
          class="navbar-toggler"
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#navbarNav"
        >
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav me-auto">
            <li class="nav-item">
              <a class="nav-link" href="/admin/dashboard">Dashboard</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/admin/volunteers">Volunteers</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/admin/blogs">Blogs</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/admin/media">Media</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/admin/emails">Email</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/admin/users">Users</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/admin/settings">Site Settings</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/admin/content/home">Home Content</a>
            </li>
          </ul>
          <span class="navbar-text me-3">
            <i class="bi bi-person-circle"></i> <%= user && user.username %>
          </span>
          <a class="btn btn-outline-light btn-sm" href="/admin/logout">Logout</a>
        </div>
      </div>
    </nav>
    <main class="container my-4 px-3">
      <%- body %>
    </main>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>

