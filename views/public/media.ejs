<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> - <%= (settings && settings.site_name) || 'Aaryawart Seva Nyaas' %></title>
    <meta name="description" content="Official website of <%= (settings && settings.site_name) || 'Aaryawart Seva Nyaas' %>, a social and charity organization focusing on education, healthcare, rural development, women empowerment, youth, culture, and environment." />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"
    />
    <link rel="stylesheet" href="/static/css/style.css" />
  </head>
  <body>
    <header class="border-bottom bg-light">
      <!-- Desktop Header -->
      <div class="container py-2 py-md-2 d-none d-md-flex flex-wrap justify-content-between align-items-center gap-2">
        <div class="d-flex align-items-center gap-2 gap-md-3 flex-shrink-0 min-w-0">
          <img src="<%= (settings && settings.header_logo_url) || '/static/images/logo.png' %>" alt="Logo" class="logo-img flex-shrink-0" />
          <div class="min-w-0">
            <span class="fw-bold text-primary d-block text-truncate site-name-desktop"><%= (settings && settings.site_name) || 'Aaryawart Seva Nyaas' %></span>
            <small class="text-muted d-none d-sm-inline"><%= (settings && settings.site_tagline) || 'Seva | Shiksha | Sahyog' %></small>
          </div>
        </div>
        <div class="d-flex gap-2 flex-shrink-0">
          <a href="/get-involved" class="btn btn-outline-primary btn-sm">Join Us</a>
          <a href="/get-involved#donate" class="btn btn-primary btn-sm">Donate</a>
        </div>
      </div>

      <!-- Mobile Header -->
      <div class="container py-3 d-md-none">
        <div class="d-flex flex-column align-items-center text-center gap-2">
          <img src="<%= (settings && settings.header_logo_url) || '/static/images/logo.png' %>" alt="Logo" class="logo-img" />
          <div>
            <span class="fw-bold text-primary d-block site-name-mobile"><%= (settings && settings.site_name) || 'Aaryawart Seva Nyaas' %></span>
            <small class="text-muted d-block"><%= (settings && settings.site_tagline) || 'Seva | Shiksha | Sahyog' %></small>
          </div>
        </div>
      </div>

      <!-- Mobile Buttons -->
      <div class="container d-md-none pb-2">
        <div class="d-flex justify-content-center gap-2">
          <a href="/get-involved" class="btn btn-outline-primary btn-sm flex-grow-1 flex-md-grow-0 btn-no-min-width">Join</a>
          <a href="/get-involved#donate" class="btn btn-primary btn-sm flex-grow-1 flex-md-grow-0 btn-no-min-width">Donate</a>
        </div>
      </div>
      <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
          <a class="navbar-brand" href="/">Home</a>
          <button
            class="navbar-toggler"
            type="button"
            data-bs-toggle="collapse"
            data-bs-target="#mainNav"
            aria-controls="mainNav"
            aria-expanded="false"
            aria-label="Toggle navigation"
          >
            <span class="navbar-toggler-icon"></span>
          </button>
          <div class="collapse navbar-collapse" id="mainNav">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
              <li class="nav-item"><a class="nav-link" href="/about">About Us</a></li>
              <li class="nav-item"><a class="nav-link" href="/activities">Activities &amp; Programs</a></li>
              <li class="nav-item"><a class="nav-link" href="/media">Media &amp; Publications</a></li>
              <li class="nav-item"><a class="nav-link" href="/testimonials">Testimonials</a></li>
              <li class="nav-item"><a class="nav-link" href="/get-involved">Get Involved</a></li>
              <li class="nav-item"><a class="nav-link" href="/contact">Contact</a></li>
            </ul>
            <div class="d-flex gap-3 py-2 py-lg-0 justify-content-center justify-content-lg-end flex-wrap">
              <% let socialLinks = []; try { socialLinks = settings && settings.social_links_json ? JSON.parse(settings.social_links_json) : []; } catch (e) { socialLinks = []; } %>
              <% if (!socialLinks.length) { %>
                <a href="https://www.facebook.com/people/Aaryawart-Seva-Nyaas/61585981201970/" class="text-white text-decoration-none" aria-label="Facebook"><i class="bi bi-facebook"></i></a>
                <a href="https://x.com/seva_nyaas" class="text-white text-decoration-none" aria-label="Twitter"><i class="bi bi-twitter-x"></i></a>
                <a href="https://www.instagram.com/aaryawart_seva_nyaas/" class="text-white text-decoration-none" aria-label="Instagram"><i class="bi bi-instagram"></i></a>
                <a href="https://www.youtube.com/@aaryawartastroworld" class="text-white text-decoration-none" aria-label="YouTube"><i class="bi bi-youtube"></i></a>
                <a href="https://linkedin.com" class="text-white text-decoration-none" aria-label="LinkedIn"><i class="bi bi-linkedin"></i></a>
              <% } else { %>
                <% socialLinks.forEach(function(link) { %>
                  <a href="<%= link.url %>" class="text-white text-decoration-none" aria-label="<%= link.id %>"><i class="bi <%= link.icon %>"></i></a>
                <% }); %>
              <% } %>
            </div>
          </div>
        </div>
      </nav>
      <div class="news-ticker bg-warning text-dark">
        <div class="container">
          <div class="ticker-wrapper">
            <span class="fw-bold me-2 ticker-label">Latest:</span>
            <div class="ticker-content">
              <span class="ticker-text">
                <%= (settings && settings.news_ticker_text) || 'Upcoming health camp in rural districts • National youth leadership workshop • Flood relief volunteer deployment • New education centers inaugurated' %>
              </span>
            </div>
          </div>
        </div>
      </div>
    </header>

    <main>

<section class="py-5">
    <div class="container">
      <h1 class="mb-4">Media & Publications</h1>

      <h2 class="mb-3">Blog & News</h2>
      <div id="blogs-container">
        <% if (blogs && blogs.length) { %>
          <div id="blogs-list">
            <div class="row row-cols-1 row-cols-md-2 g-3 mb-4">
              <% blogs.forEach(function(blog) { %>
                <div class="col">
                  <div class="card h-100 cursor-pointer blog-card" data-blog-id="<%= blog.id %>">
                    <% if (blog.featured_image) { %>
                      <img src="<%= blog.featured_image %>" class="card-img-top" alt="<%= escapeHtml(blog.title) %>" />
                    <% } %>
                    <div class="card-body d-flex flex-column">
                      <h5 class="card-title"><%= escapeHtml(blog.title) %></h5>
                      <p class="card-text text-muted small mb-2"><%= escapeHtml(blog.category || 'General') %> • <%= escapeHtml(new Date(blog.publish_date).toLocaleDateString()) %></p>
                      <p class="card-text flex-grow-1"><%= escapeHtml((blog.content || '').replace(/<[^>]+>/g, '').substring(0, 150)) %>...</p>
                      <button class="btn btn-sm btn-primary mt-auto read-more-btn" data-blog-id="<%= blog.id %>">Read More</button>
                    </div>
                  </div>
                </div>
              <% }); %>
            </div>
          </div>
          <div id="blog-detail" class="blog-detail-section mb-4" style="display: none;">
            <button class="btn btn-secondary btn-sm mb-3" id="back-to-list">← Back to List</button>
            <article class="blog-detail-content"></article>
          </div>
        <% } else { %>
          <p class="text-muted">Loading blog posts...</p>
        <% } %>
      </div>

      <hr class="my-4" />

      <h2 class="mb-3">Photo Gallery</h2>
      <div class="row row-cols-2 row-cols-md-4 g-3">
        <div class="col">
          <img src="/static/images/gallery1.jpg" class="img-fluid rounded" alt="Gallery 1" />
        </div>
        <div class="col">
          <img src="/static/images/gallery2.jpg" class="img-fluid rounded" alt="Gallery 2" />
        </div>
        <div class="col">
          <img src="/static/images/gallery3.jpg" class="img-fluid rounded" alt="Gallery 3" />
        </div>
        <div class="col">
          <img src="/static/images/gallery4.jpg" class="img-fluid rounded" alt="Gallery 4" />
        </div>
      </div>

      <hr class="my-4" />

      <h2 class="mb-3">Video Gallery</h2>
      <div class="row row-cols-1 row-cols-md-2 g-3">
        <div class="col">
          <div class="ratio ratio-16x9">
            <iframe src="https://www.youtube.com/embed/dQw4w9WgXcQ" title="Video 1" allowfullscreen></iframe>
          </div>
        </div>
        <div class="col">
          <div class="ratio ratio-16x9">
            <iframe src="https://www.youtube.com/embed/dQw4w9WgXcQ" title="Video 2" allowfullscreen></iframe>
          </div>
        </div>
      </div>

      <hr class="my-4" />

      <h2 class="mb-3">Publications</h2>
      <ul>
        <li><a href="/static/docs/newsletter-jan-2024.pdf" target="_blank">Monthly Newsletter - Jan 2024</a></li>
        <li><a href="/static/docs/newsletter-dec-2023.pdf" target="_blank">Monthly Newsletter - Dec 2023</a></li>
        <li><a href="/static/docs/magazine-2023.pdf" target="_blank">Annual Magazine 2023</a></li>
      </ul>

      <hr class="my-4" />

      <h2 class="mb-3">Media Coverage & Speeches</h2>
      <p class="small">
        Archive of press clippings, media interviews, and keynote speeches can be linked here as PDF, audio,
        or video, using the media library in the admin panel.
      </p>
    </div>
  </section>

    </main>

    <footer class="bg-dark text-white mt-5 pt-4 pb-3">
      <div class="container">
        <div class="row">
          <div class="col-md-4 mb-3">
            <h5>About</h5>
            <p class="small">
              <%= (settings && settings.footer_about) || 'A nationwide social and cultural organization dedicated to selfless service, character building, and national integration through thousands of volunteers and grassroots projects.' %>
            </p>
          </div>
          <div class="col-md-4 mb-3">
            <h5>Quick Links</h5>
            <ul class="list-unstyled small">
              <% let quickLinks = []; try { quickLinks = settings && settings.footer_quick_links_json ? JSON.parse(settings.footer_quick_links_json) : []; } catch (e) { quickLinks = []; } %>
              <% if (!quickLinks.length) { %>
                <li><a href="/about" class="text-white text-decoration-none">About Us</a></li>
                <li><a href="/activities" class="text-white text-decoration-none">Activities</a></li>
                <li><a href="/media" class="text-white text-decoration-none">Media</a></li>
                <li><a href="/get-involved" class="text-white text-decoration-none">Volunteer / Donate</a></li>
                <li><a href="/contact" class="text-white text-decoration-none">Contact</a></li>
              <% } else { %>
                <% quickLinks.forEach(function(link) { %>
                  <li><a href="<%= link.url %>" class="text-white text-decoration-none"><%= link.label %></a></li>
                <% }); %>
              <% } %>
            </ul>
          </div>
          <div class="col-md-4 mb-3">
            <h5>Contact</h5>
            <% const footerContact = (settings && settings.footer_contact) || '113, Shivalik Nagar, BHEL, Haridwar, UK, India (249403)\nEmail: aaryawartsevanyaas@gmail.com\nPhone: +91-9253999082, 9253999083'; %>
            <% footerContact.split(/\r?\n/).forEach(function(line) { %>
              <p class="small mb-1"><%= line %></p>
            <% }); %>
          </div>
        </div>
        <div class="text-center small mt-3">
          &copy; <%= new Date().getFullYear() %> <%= (settings && settings.site_name) || 'Aaryawart Seva Nyaas' %>. All rights reserved.
        </div>
      </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/static/js/main.js"></script>
    
    <script>
      (async function() {
        const container = document.getElementById('blogs-container');

        try {
          const response = await fetch('/api/blogs?limit=20');
          if (!response.ok) {
            throw new Error(`HTTP error! status: ${response.status}`);
          }

          const result = await response.json();
          if (!result.success || !Array.isArray(result.data) || result.data.length === 0) {
            container.innerHTML = '<p class="text-muted">No blog posts available yet.</p>';
            return;
          }

          const hashMatch = window.location.hash.match(/blog-(\d+)/);
          const selectedBlogId = hashMatch ? parseInt(hashMatch[1], 10) : null;

          function formatDate(value) {
            const date = new Date(value);
            return isNaN(date.getTime()) ? String(value) : date.toLocaleDateString();
          }

          function escapeText(text) {
            return String(text || '')
              .replace(/&/g, '&amp;')
              .replace(/</g, '&lt;')
              .replace(/>/g, '&gt;');
          }

          function renderExcerpt(content) {
            return escapeText((content || '').replace(/<[^>]+>/g, '').substring(0, 150));
          }

          async function showBlogDetail(event) {
            event.preventDefault();
            const blogId = event.currentTarget.getAttribute('data-blog-id');
            if (!blogId) return;

            try {
              const blogResponse = await fetch(`/api/blogs/${blogId}`);
              if (!blogResponse.ok) {
                alert('Error loading blog post');
                return;
              }

              const blogResult = await blogResponse.json();
              if (!blogResult.success || !blogResult.data) {
                alert('Blog post not found');
                return;
              }

              const blog = blogResult.data;
              const detailContent = document.querySelector('.blog-detail-content');

              detailContent.innerHTML = `
                <h2>${escapeText(blog.title)}</h2>
                <p class="text-muted">
                  <small><strong>By ${escapeText(blog.author)}</strong> • ${escapeText(blog.category || 'General')} • ${escapeText(formatDate(blog.publish_date))}</small>
                </p>
                ${blog.featured_image ? `<img src="${blog.featured_image}" class="img-fluid mb-3 rounded" alt="${escapeText(blog.title)}" />` : ''}
                <div class="blog-content">
                  ${blog.content || ''}
                </div>
              `;

              document.getElementById('blogs-list').style.display = 'none';
              document.getElementById('blog-detail').style.display = 'block';
              window.location.hash = `blog-${blogId}`;
              window.scrollTo({ top: 0, behavior: 'smooth' });
            } catch (err) {
              console.error('Error loading blog detail:', err);
              alert('Error loading blog post');
            }
          }

          window.showBlogDetail = showBlogDetail;

          const blogCards = result.data.map(blog => {
            const excerpt = renderExcerpt(blog.content);
            return `
              <div class="col">
                <div class="card h-100 cursor-pointer blog-card" data-blog-id="${blog.id}">
                  ${blog.featured_image ? `<img src="${blog.featured_image}" class="card-img-top" alt="${escapeText(blog.title)}" />` : ''}
                  <div class="card-body d-flex flex-column">
                    <h5 class="card-title">${escapeText(blog.title)}</h5>
                    <p class="card-text text-muted small mb-2">${escapeText(blog.category || 'General')} • ${escapeText(formatDate(blog.publish_date))}</p>
                    <p class="card-text flex-grow-1">${excerpt}...</p>
                    <button class="btn btn-sm btn-primary mt-auto read-more-btn" data-blog-id="${blog.id}">Read More</button>
                  </div>
                </div>
              </div>
            `;
          }).join('');

          container.innerHTML = `
            <div id="blogs-list">
              <div class="row row-cols-1 row-cols-md-2 g-3 mb-4">
                ${blogCards}
              </div>
            </div>
            <div id="blog-detail" class="blog-detail-section mb-4" style="display: none;">
              <button class="btn btn-secondary btn-sm mb-3" id="back-to-list">← Back to List</button>
              <article class="blog-detail-content"></article>
            </div>
          `;

          const listSection = document.getElementById('blogs-list');
          const detailSection = document.getElementById('blog-detail');

          container.querySelectorAll('.read-more-btn').forEach(btn => {
            btn.addEventListener('click', showBlogDetail);
          });

          container.querySelectorAll('.blog-card').forEach(card => {
            card.addEventListener('click', function(event) {
              if (event.target.closest('.read-more-btn')) return;
              const btn = this.querySelector('.read-more-btn');
              if (btn) btn.click();
            });
          });

          document.getElementById('back-to-list').addEventListener('click', function(event) {
            event.preventDefault();
            detailSection.style.display = 'none';
            listSection.style.display = 'block';
            window.location.hash = '#blogs-container';
          });

          if (selectedBlogId) {
            const selectedButton = container.querySelector(`.read-more-btn[data-blog-id="${selectedBlogId}"]`);
            if (selectedButton) {
              selectedButton.click();
            }
          }
        } catch (err) {
          console.error('Error fetching blogs:', err);
          container.innerHTML = `<p class="text-danger">Error loading blog posts: ${escapeText(err.message)}</p>`;
        }
      })();
    </script>
  </body>
</html>
