<%- include('_header', { title }) %>

  <section class="py-5">
    <div class="container">
      <h1 class="mb-4">Activities & Programs</h1>
      <div class="row row-cols-1 row-cols-md-2 g-4">
        <div class="col">
          <div class="card h-100">
            <div class="card-body">
              <h3 class="card-title">Education Initiatives</h3>
              <p class="card-text">
                Evening tuition centers, competitive exam coaching, hostels for rural students,
                and value-based education workshops in schools and colleges.
              </p>
            </div>
          </div>
        </div>
        <div class="col">
          <div class="card h-100">
            <div class="card-body">
              <h3 class="card-title">Healthcare Services</h3>
              <p class="card-text">
                Free medical camps, telemedicine, blood donation drives, eye check-up camps,
                nutrition support for children, and elderly care services.
              </p>
            </div>
          </div>
        </div>
        <div class="col">
          <div class="card h-100">
            <div class="card-body">
              <h3 class="card-title">Rural Development</h3>
              <p class="card-text">
                Village adoption, watershed management, organic farming promotion,
                self-help groups, and livelihood training for farmers and artisans.
              </p>
            </div>
          </div>
        </div>
        <div class="col">
          <div class="card h-100">
            <div class="card-body">
              <h3 class="card-title">Women Empowerment</h3>
              <p class="card-text">
                Skill development, self-defense training, health awareness, leadership workshops,
                and support networks for women entrepreneurs.
              </p>
            </div>
          </div>
        </div>
        <div class="col">
          <div class="card h-100">
            <div class="card-body">
              <h3 class="card-title">Disaster Relief</h3>
              <p class="card-text">
                Swift response teams for floods, earthquakes, and pandemics;
                distribution of relief materials, rehabilitation, and psychological support.
              </p>
            </div>
          </div>
        </div>
        <div class="col">
          <div class="card h-100">
            <div class="card-body">
              <h3 class="card-title">Cultural Preservation</h3>
              <p class="card-text">
                Festivals, traditional arts, Sanskrit promotion, heritage walks, and
                inter-cultural dialogue in the spirit of harmony.
              </p>
            </div>
          </div>
        </div>
        <div class="col">
          <div class="card h-100">
            <div class="card-body">
              <h3 class="card-title">Youth Programs</h3>
              <p class="card-text">
                Leadership camps, personality development, sports, adventure treks,
                and nation-building projects led by students and young professionals.
              </p>
            </div>
          </div>
        </div>
        <div class="col">
          <div class="card h-100">
            <div class="card-body">
              <h3 class="card-title">Environmental Projects</h3>
              <p class="card-text">
                Tree plantation drives, cleanliness campaigns, plastic-free initiatives,
                river and lake rejuvenation, and environmental education.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

<%- include('_footer') %>
