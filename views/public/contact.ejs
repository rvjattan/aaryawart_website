<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> - <%= (settings && settings.site_name) || 'Aaryawart Seva Nyaas' %></title>
    <meta name="description" content="Official website of <%= (settings && settings.site_name) || 'Aaryawart Seva Nyaas' %>, a social and charity organization focusing on education, healthcare, rural development, women empowerment, youth, culture, and environment." />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"
    />
    <link rel="stylesheet" href="/static/css/style.css" />
  </head>
  <body>
    <header class="border-bottom bg-light">
      <!-- Desktop Header -->
      <div class="container py-2 py-md-2 d-none d-md-flex flex-wrap justify-content-between align-items-center gap-2">
        <div class="d-flex align-items-center gap-2 gap-md-3 flex-shrink-0 min-w-0">
          <img src="<%= (settings && settings.header_logo_url) || '/static/images/logo.png' %>" alt="Logo" class="logo-img flex-shrink-0" />
          <div class="min-w-0">
            <span class="fw-bold text-primary d-block text-truncate site-name-desktop"><%= (settings && settings.site_name) || 'Aaryawart Seva Nyaas' %></span>
            <small class="text-muted d-none d-sm-inline"><%= (settings && settings.site_tagline) || 'Seva | Shiksha | Sahyog' %></small>
          </div>
        </div>
        <div class="d-flex gap-2 flex-shrink-0">
          <a href="/get-involved" class="btn btn-outline-primary btn-sm">Join Us</a>
          <a href="/get-involved#donate" class="btn btn-primary btn-sm">Donate</a>
        </div>
      </div>

      <!-- Mobile Header -->
      <div class="container py-3 d-md-none">
        <div class="d-flex flex-column align-items-center text-center gap-2">
          <img src="<%= (settings && settings.header_logo_url) || '/static/images/logo.png' %>" alt="Logo" class="logo-img" />
          <div>
            <span class="fw-bold text-primary d-block site-name-mobile"><%= (settings && settings.site_name) || 'Aaryawart Seva Nyaas' %></span>
            <small class="text-muted d-block"><%= (settings && settings.site_tagline) || 'Seva | Shiksha | Sahyog' %></small>
          </div>
        </div>
      </div>

      <!-- Mobile Buttons -->
      <div class="container d-md-none pb-2">
        <div class="d-flex justify-content-center gap-2">
          <a href="/get-involved" class="btn btn-outline-primary btn-sm flex-grow-1 flex-md-grow-0 btn-no-min-width">Join</a>
          <a href="/get-involved#donate" class="btn btn-primary btn-sm flex-grow-1 flex-md-grow-0 btn-no-min-width">Donate</a>
        </div>
      </div>
      <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
          <a class="navbar-brand" href="/">Home</a>
          <button
            class="navbar-toggler"
            type="button"
            data-bs-toggle="collapse"
            data-bs-target="#mainNav"
            aria-controls="mainNav"
            aria-expanded="false"
            aria-label="Toggle navigation"
          >
            <span class="navbar-toggler-icon"></span>
          </button>
          <div class="collapse navbar-collapse" id="mainNav">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
              <li class="nav-item"><a class="nav-link" href="/about">About Us</a></li>
              <li class="nav-item"><a class="nav-link" href="/activities">Activities &amp; Programs</a></li>
              <li class="nav-item"><a class="nav-link" href="/media">Media &amp; Publications</a></li>
              <li class="nav-item"><a class="nav-link" href="/testimonials">Testimonials</a></li>
              <li class="nav-item"><a class="nav-link" href="/get-involved">Get Involved</a></li>
              <li class="nav-item"><a class="nav-link" href="/contact">Contact</a></li>
            </ul>
            <div class="d-flex gap-3 py-2 py-lg-0 justify-content-center justify-content-lg-end flex-wrap">
              <% let socialLinks = []; try { socialLinks = settings && settings.social_links_json ? JSON.parse(settings.social_links_json) : []; } catch (e) { socialLinks = []; } %>
              <% if (!socialLinks.length) { %>
                <a href="https://www.facebook.com/people/Aaryawart-Seva-Nyaas/61585981201970/" class="text-white text-decoration-none" aria-label="Facebook"><i class="bi bi-facebook"></i></a>
                <a href="https://x.com/aaryawartastro" class="text-white text-decoration-none" aria-label="Twitter"><i class="bi bi-twitter-x"></i></a>
                <a href="https://www.instagram.com/aaryawart_seva_nyaas/" class="text-white text-decoration-none" aria-label="Instagram"><i class="bi bi-instagram"></i></a>
                <a href="https://www.youtube.com/@aaryawartastroworld" class="text-white text-decoration-none" aria-label="YouTube"><i class="bi bi-youtube"></i></a>
                <a href="https://linkedin.com" class="text-white text-decoration-none" aria-label="LinkedIn"><i class="bi bi-linkedin"></i></a>
              <% } else { %>
                <% socialLinks.forEach(function(link) { %>
                  <a href="<%= link.url %>" class="text-white text-decoration-none" aria-label="<%= link.id %>"><i class="bi <%= link.icon %>"></i></a>
                <% }); %>
              <% } %>
            </div>
          </div>
        </div>
      </nav>
      <div class="news-ticker bg-warning text-dark">
        <div class="container">
          <span class="fw-bold me-2">Latest:</span>
          <marquee behavior="scroll" direction="left">
            <%= (settings && settings.news_ticker_text) || 'Upcoming health camp in rural districts • National youth leadership workshop • Flood relief volunteer deployment • New education centers inaugurated' %>
          </marquee>
        </div>
      </div>
    </header>

    <main>

<section class="py-5">
    <div class="container">
      <h1 class="mb-4">Contact & Locations</h1>
      <div class="row">
        <div class="col-md-6">
          <h3>Contact Form</h3>
          <p class="small">Send us your queries or feedback. This can be wired to send emails using SMTP.</p>
          <form>
            <div class="mb-3">
              <label class="form-label">Name</label>
              <input type="text" class="form-control" required />
            </div>
            <div class="mb-3">
              <label class="form-label">Email</label>
              <input type="email" class="form-control" required />
            </div>
            <div class="mb-3">
              <label class="form-label">Message</label>
              <textarea class="form-control" rows="4" required></textarea>
            </div>
            <button type="submit" class="btn btn-primary">Send</button>
          </form>
        </div>
        <div class="col-md-6">
          <h3>Head Office</h3>
          <p>
            Aaryawart Seva Nyaas<br />
            113, Shivalik Nagar, BHEL, Haridwar, UK, India (249403)<br />
            Phone: +91-9253999082<br />
            Email: aaryawartsevanyaas@gmail.com
          </p>
          <h4 class="mt-4">State Branches</h4>
          <ul class="small">
            <li>Haryana – Ambala, Bhiwani, Charkhi Dadri, Chandigarh, Mahendergarh, Narnaul, Panipat, Rohtak </li>
            <li>Maharashtra – Mumbai, Pune, Nagpur</li>
            <li>Uttar Pradesh – Lucknow, Varanasi, Kanpur</li>
            <li>Tamil Nadu – Chennai, Coimbatore, Madurai</li>
            <li>Assam – Guwahati, Dibrugarh, Silchar</li>
            <li>… and many more across India</li>
          </ul>

          <h4 class="mt-4">Interactive Map</h4>
          <p class="small">
            Integrate Google Maps here to show all local chapters with markers.
          </p>
          <div class="ratio ratio-16x9">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3502.199540716501!2d77.215!3d28.619!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMjjCsDM3JzA4LjQiTiA3N8KwMTInNTQuMCJF!5e0!3m2!1sen!2sin!4v1616580000000!5m2!1sen!2sin"
              class="iframe-no-border"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
            ></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>

    </main>

    <footer class="bg-dark text-white mt-5 pt-4 pb-3">
      <div class="container">
        <div class="row">
          <div class="col-md-4 mb-3">
            <h5>About</h5>
            <p class="small">
              <%= (settings && settings.footer_about) || 'A nationwide social and cultural organization dedicated to selfless service, character building, and national integration through thousands of volunteers and grassroots projects.' %>
            </p>
          </div>
          <div class="col-md-4 mb-3">
            <h5>Quick Links</h5>
            <ul class="list-unstyled small">
              <% let quickLinks = []; try { quickLinks = settings && settings.footer_quick_links_json ? JSON.parse(settings.footer_quick_links_json) : []; } catch (e) { quickLinks = []; } %>
              <% if (!quickLinks.length) { %>
                <li><a href="/about" class="text-white text-decoration-none">About Us</a></li>
                <li><a href="/activities" class="text-white text-decoration-none">Activities</a></li>
                <li><a href="/media" class="text-white text-decoration-none">Media</a></li>
                <li><a href="/get-involved" class="text-white text-decoration-none">Volunteer / Donate</a></li>
                <li><a href="/contact" class="text-white text-decoration-none">Contact</a></li>
              <% } else { %>
                <% quickLinks.forEach(function(link) { %>
                  <li><a href="<%= link.url %>" class="text-white text-decoration-none"><%= link.label %></a></li>
                <% }); %>
              <% } %>
            </ul>
          </div>
          <div class="col-md-4 mb-3">
            <h5>Contact</h5>
            <% const footerContact = (settings && settings.footer_contact) || '113, Shivalik Nagar, BHEL, Haridwar, UK, India (249403)\nEmail: aaryawartsevanyaas@gmail.com\nPhone: +91-9253999082, 9253999083'; %>
            <% footerContact.split(/\r?\n/).forEach(function(line) { %>
              <p class="small mb-1"><%= line %></p>
            <% }); %>
          </div>
        </div>
        <div class="text-center small mt-3">
          &copy; <%= new Date().getFullYear() %> <%= (settings && settings.site_name) || 'Aaryawart Seva Nyaas' %>. All rights reserved.
        </div>
      </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/static/js/main.js"></script>
  </body>
</html>
