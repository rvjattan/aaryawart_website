<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> - <%= (settings && settings.site_name) || 'Aaryawart Seva Nyaas' %></title>
    <meta name="description" content="Official website of <%= (settings && settings.site_name) || 'Aaryawart Seva Nyaas' %>, a social and charity organization focusing on education, healthcare, rural development, women empowerment, youth, culture, and environment." />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"
    />
    <link rel="stylesheet" href="/static/css/style.css" />
  </head>
  <body>
    <header class="border-bottom bg-light">
      <!-- Desktop Header -->
      <div class="container py-2 py-md-2 d-none d-md-flex flex-wrap justify-content-between align-items-center gap-2">
        <div class="d-flex align-items-center gap-2 gap-md-3 flex-shrink-0 min-w-0">
          <img src="<%= (settings && settings.header_logo_url) || '/static/images/logo.png' %>" alt="Logo" class="logo-img flex-shrink-0" />
          <div class="min-w-0">
            <span class="fw-bold text-primary d-block text-truncate site-name-desktop"><%= (settings && settings.site_name) || 'Aaryawart Seva Nyaas' %></span>
            <small class="text-muted d-none d-sm-inline"><%= (settings && settings.site_tagline) || 'Seva | Shiksha | Sahyog' %></small>
          </div>
        </div>
        <div class="d-flex gap-2 flex-shrink-0">
          <a href="/get-involved" class="btn btn-outline-primary btn-sm">Join Us</a>
          <a href="/get-involved#donate" class="btn btn-primary btn-sm">Donate</a>
        </div>
      </div>

      <!-- Mobile Header -->
      <div class="container py-3 d-md-none">
        <div class="d-flex flex-column align-items-center text-center gap-2">
          <img src="<%= (settings && settings.header_logo_url) || '/static/images/logo.png' %>" alt="Logo" class="logo-img" />
          <div>
            <span class="fw-bold text-primary d-block site-name-mobile"><%= (settings && settings.site_name) || 'Aaryawart Seva Nyaas' %></span>
            <small class="text-muted d-block"><%= (settings && settings.site_tagline) || 'Seva | Shiksha | Sahyog' %></small>
          </div>
        </div>
      </div>

      <!-- Mobile Buttons -->
      <div class="container d-md-none pb-2">
        <div class="d-flex justify-content-center gap-2">
          <a href="/get-involved" class="btn btn-outline-primary btn-sm flex-grow-1 flex-md-grow-0 btn-no-min-width">Join</a>
          <a href="/get-involved#donate" class="btn btn-primary btn-sm flex-grow-1 flex-md-grow-0 btn-no-min-width">Donate</a>
        </div>
      </div>
      <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
          <a class="navbar-brand" href="/">Home</a>
          <button
            class="navbar-toggler"
            type="button"
            data-bs-toggle="collapse"
            data-bs-target="#mainNav"
            aria-controls="mainNav"
            aria-expanded="false"
            aria-label="Toggle navigation"
          >
            <span class="navbar-toggler-icon"></span>
          </button>
          <div class="collapse navbar-collapse" id="mainNav">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
              <li class="nav-item"><a class="nav-link" href="/about">About Us</a></li>
              <li class="nav-item"><a class="nav-link" href="/activities">Activities &amp; Programs</a></li>
              <li class="nav-item"><a class="nav-link" href="/media">Media &amp; Publications</a></li>
              <li class="nav-item"><a class="nav-link" href="/testimonials">Testimonials</a></li>
              <li class="nav-item"><a class="nav-link" href="/get-involved">Get Involved</a></li>
              <li class="nav-item"><a class="nav-link" href="/contact">Contact</a></li>
            </ul>
            <div class="d-flex gap-3 py-2 py-lg-0 justify-content-center justify-content-lg-end flex-wrap">
              <% let socialLinks = []; try { socialLinks = settings && settings.social_links_json ? JSON.parse(settings.social_links_json) : []; } catch (e) { socialLinks = []; } %>
              <% if (!socialLinks.length) { %>
                <a href="https://www.facebook.com/people/Aaryawart-Seva-Nyaas/61585981201970/" class="text-white text-decoration-none" aria-label="Facebook"><i class="bi bi-facebook"></i></a>
                <a href="https://x.com/seva_nyaas" class="text-white text-decoration-none" aria-label="Twitter"><i class="bi bi-twitter-x"></i></a>
                <a href="https://www.instagram.com/aaryawart_seva_nyaas/" class="text-white text-decoration-none" aria-label="Instagram"><i class="bi bi-instagram"></i></a>
                <a href="https://www.youtube.com/@aaryawartastroworld" class="text-white text-decoration-none" aria-label="YouTube"><i class="bi bi-youtube"></i></a>
                <a href="https://linkedin.com" class="text-white text-decoration-none" aria-label="LinkedIn"><i class="bi bi-linkedin"></i></a>
              <% } else { %>
                <% socialLinks.forEach(function(link) { %>
                  <a href="<%= link.url %>" class="text-white text-decoration-none" aria-label="<%= link.id %>"><i class="bi <%= link.icon %>"></i></a>
                <% }); %>
              <% } %>
            </div>
          </div>
        </div>
      </nav>
      <div class="news-ticker bg-warning text-dark">
        <div class="container">
          <div class="ticker-wrapper">
            <span class="fw-bold me-2 ticker-label">Latest:</span>
            <div class="ticker-content">
              <span class="ticker-text">
                <%= (settings && settings.news_ticker_text) || 'Upcoming health camp in rural districts • National youth leadership workshop • Flood relief volunteer deployment • New education centers inaugurated' %>
              </span>
            </div>
          </div>
        </div>
      </div>
    </header>

    <main>

<section class="py-5">
    <div class="container">
      <h1 class="mb-4">Get Involved</h1>
      <div class="row">
        <div class="col-md-7">
          <h3>Volunteer Registration</h3>
          <p>Fill the form below to join our volunteer network.</p>
          <div id="volunteer-alert" class="alert d-none" role="alert"></div>
          <form id="volunteer-form">
            <div class="row">
              <div class="col-md-6 mb-3">
                <label class="form-label">Name <span class="text-danger">*</span></label>
                <input type="text" name="name" class="form-control" required />
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label">Email <span class="text-danger">*</span></label>
                <input 
                  type="email" 
                  name="email" 
                  id="email-input"
                  class="form-control" 
                  required 
                />
                <div class="invalid-feedback d-block d-none" id="email-error"></div>
              </div>
            </div>
            <div class="row">
              <div class="col-md-6 mb-3">
                <label class="form-label">Mobile Number <span class="text-danger">*</span></label>
                <input 
                  type="tel" 
                  name="phone" 
                  class="form-control" 
                  id="phone-input"
                  maxlength="20"
                  required 
                />
                <small class="text-muted d-block mt-1">Exactly 10 digits, starting with 6, 7, 8, or 9. Letters and special characters will be removed.</small>
                <div class="invalid-feedback d-block d-none" id="phone-error"></div>
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label">State <span class="text-danger">*</span></label>
                <div class="position-relative">
                  <input 
                    type="text" 
                    name="state" 
                    id="state-input"
                    class="form-control"
                    required
                    autocomplete="off"
                    placeholder="Start typing to see suggestions..."
                  />
                  <div class="position-absolute bg-white border rounded mt-1 w-100" id="state-suggestions" style="display: none; max-height: 200px; overflow-y: auto; z-index: 1000; top: 100%;"></div>
                </div>
                <div class="invalid-feedback d-block d-none" id="state-error"></div>
              </div>
            </div>
            <div class="row">
              <div class="col-md-6 mb-3">
                <label class="form-label">City <span class="text-danger">*</span></label>
                <div class="position-relative">
                  <input 
                    type="text" 
                    name="city" 
                    id="city-input"
                    class="form-control"
                    required
                    autocomplete="off"
                    placeholder="Start typing to see suggestions..."
                  />
                  <div class="position-absolute bg-white border rounded mt-1 w-100" id="city-suggestions" style="display: none; max-height: 200px; overflow-y: auto; z-index: 1000; top: 100%;"></div>
                </div>
                <div class="invalid-feedback d-block d-none" id="city-error"></div>
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label">Availability</label>
                <input type="text" name="availability" class="form-control" placeholder="Weekends, evenings, etc." />
              </div>
            </div>
            <div class="mb-3">
              <label class="form-label">Address</label>
              <input type="text" name="address" class="form-control" />
            </div>
            <div class="mb-3">
              <label class="form-label">Skills</label>
              <textarea name="skills" class="form-control" rows="3" placeholder="Teaching, medical, IT, organizing, arts, etc."></textarea>
            </div>
            <button type="submit" class="btn btn-primary">Submit</button>
          </form>
        </div>
        <div class="col-md-5">
          <h3>Volunteer Opportunities</h3>
          <ul>
            <li>Teaching support in slum and rural schools</li>
            <li>Health camps and hospital support</li>
            <li>Disaster relief and rehabilitation</li>
            <li>Environmental campaigns and cleanliness drives</li>
            <li>Cultural programs and festivals</li>
            <li>Youth leadership and mentoring</li>
          </ul>

          <hr class="my-4" id="donate" />

          <h3>Donate</h3>
          <p class="small">
            You can support our work through one-time or recurring contributions.
            At present, online donations are temporarily unavailable.
          </p>
          <p class="small text-muted">
            For bank transfers and 80G certificates, please contact our national office. Details will be shared with you by email.
          </p>

          <hr class="my-4" />

          <h3>Become a Member / Start a Chapter</h3>
          <p class="small">
            To become a formal member or start a local chapter in your city or village,
            please write to membership@yourorg.org with your profile, proposed activities,
            and local contacts. Our team will guide you through the process and provide
            orientation material.
          </p>

          <h3>Corporate Partnerships</h3>
          <p class="small">
            We welcome CSR collaborations for sustained impact projects in education,
            health, rural development, environment, and youth empowerment. Write to
            csr@yourorg.org for detailed project proposals and reports.
          </p>
        </div>
      </div>
    </div>
  </section>

  <script src="/static/js/states-cities.js"></script>
  <script>
    // Validation functions
    const validators = {
      email: (email) => {
        // Check for no spaces
        if (email !== email.trim()) return false;
        // Check format: chars before @, domain after @, valid TLD (2+ chars after last dot)
        const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/;
        return emailRegex.test(email);
      },
      phone: (phone) => {
        // Remove all non-digits
        const digitsOnly = phone.replace(/\D/g, '');
        // Check if exactly 10 digits
        if (digitsOnly.length !== 10) return false;
        // Check if first digit is 6, 7, 8, or 9
        const firstDigit = digitsOnly[0];
        return ['6', '7', '8', '9'].includes(firstDigit);
      }
    };

    // Initialize state and city autocomplete with custom dropdown
    document.addEventListener('DOMContentLoaded', () => {
      const stateInput = document.getElementById('state-input');
      const cityInput = document.getElementById('city-input');
      const stateSuggestionsBox = document.getElementById('state-suggestions');
      const citySuggestionsBox = document.getElementById('city-suggestions');
      const emailInput = document.getElementById('email-input');
      const phoneInput = document.getElementById('phone-input');
      const emailError = document.getElementById('email-error');
      const phoneError = document.getElementById('phone-error');

      // Helper function to create suggestion items
      function createSuggestionItem(text, isSelected = false) {
        const div = document.createElement('div');
        div.className = 'px-3 py-2 cursor-pointer';
        div.style.cursor = 'pointer';
        div.style.backgroundColor = isSelected ? '#e7f3ff' : 'white';
        div.textContent = text;
        div.setAttribute('data-value', text);
        
        div.addEventListener('mouseover', () => {
          div.style.backgroundColor = '#e7f3ff';
        });
        div.addEventListener('mouseout', () => {
          div.style.backgroundColor = 'white';
        });
        
        return div;
      }

      // State autocomplete
      let stateSelectedIndex = -1;
      stateInput.addEventListener('input', (e) => {
        const value = e.target.value.trim();
        const suggestions = value ? getStatesSuggestions(value) : getStates();
        
        // Clear previous suggestions
        stateSuggestionsBox.innerHTML = '';
        stateSuggestionsBox.style.display = suggestions.length > 0 ? 'block' : 'none';
        stateSelectedIndex = -1;
        
        // Add new suggestions
        suggestions.slice(0, 10).forEach(state => {
          const item = createSuggestionItem(state);
          item.addEventListener('click', () => {
            stateInput.value = state;
            stateSuggestionsBox.style.display = 'none';
            cityInput.focus();
            cityInput.value = '';
            // Update city suggestions for the selected state
            updateCitySuggestions(state, '');
          });
          stateSuggestionsBox.appendChild(item);
        });
      });

      // City autocomplete
      let citySelectedIndex = -1;
      cityInput.addEventListener('input', (e) => {
        const value = e.target.value.trim();
        const state = stateInput.value.trim();
        updateCitySuggestions(state, value);
      });

      function updateCitySuggestions(state, inputValue) {
        const suggestions = getCitiesSuggestions(state, inputValue);
        
        // Clear previous suggestions
        citySuggestionsBox.innerHTML = '';
        citySuggestionsBox.style.display = suggestions.length > 0 ? 'block' : 'none';
        citySelectedIndex = -1;
        
        // Add new suggestions
        suggestions.slice(0, 10).forEach(city => {
          const item = createSuggestionItem(city);
          item.addEventListener('click', () => {
            cityInput.value = city;
            citySuggestionsBox.style.display = 'none';
          });
          citySuggestionsBox.appendChild(item);
        });
      }

      // Close suggestions when clicking outside
      document.addEventListener('click', (e) => {
        if (e.target !== stateInput && !stateSuggestionsBox.contains(e.target)) {
          stateSuggestionsBox.style.display = 'none';
        }
        if (e.target !== cityInput && !citySuggestionsBox.contains(e.target)) {
          citySuggestionsBox.style.display = 'none';
        }
      });

      // Focus to show all suggestions
      stateInput.addEventListener('focus', () => {
        if (stateSuggestionsBox.children.length === 0 || stateInput.value === '') {
          stateInput.dispatchEvent(new Event('input'));
        } else {
          stateSuggestionsBox.style.display = 'block';
        }
      });

      cityInput.addEventListener('focus', () => {
        if (stateInput.value) {
          if (citySuggestionsBox.children.length === 0 || cityInput.value === '') {
            cityInput.dispatchEvent(new Event('input'));
          } else {
            citySuggestionsBox.style.display = 'block';
          }
        }
      });

      // Real-time email validation
      emailInput.addEventListener('blur', () => {
        const email = emailInput.value.trim();
        if (email && !validators.email(email)) {
          emailError.textContent = 'Valid email required (example: user@example.com)';
          emailError.classList.remove('d-none');
        } else {
          emailError.classList.add('d-none');
        }
      });

      // Real-time phone validation
      phoneInput.addEventListener('blur', () => {
        const phone = phoneInput.value.trim();
        if (phone && !validators.phone(phone)) {
          const digitsOnly = phone.replace(/\D/g, '');
          if (digitsOnly.length !== 10) {
            phoneError.textContent = 'Must be exactly 10 digits';
          } else {
            phoneError.textContent = 'Must start with 6, 7, 8, or 9';
          }
          phoneError.classList.remove('d-none');
        } else {
          phoneError.classList.add('d-none');
        }
      });
    });

    // Form submission with validation
    const form = document.getElementById('volunteer-form');
    const alertBox = document.getElementById('volunteer-alert');

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      alertBox.classList.add('d-none');

      // Get form values
      const email = form.email.value.trim();
      const phone = form.phone.value.trim();
      const state = form.state.value.trim();
      const city = form.city.value.trim();

      // Validate email
      if (!validators.email(email)) {
        const emailInput = form.email;
        const errorEl = document.getElementById('email-error') || createErrorElement('email-error', emailInput);
        errorEl.textContent = 'Valid email address required (example: user@example.com). No spaces allowed.';
        errorEl.classList.remove('d-none');
        return;
      } else {
        const errorEl = document.getElementById('email-error');
        if (errorEl) errorEl.classList.add('d-none');
      }

      // Validate phone
      if (!validators.phone(phone)) {
        const phoneError = document.getElementById('phone-error');
        const digitsOnly = phone.replace(/\D/g, '');
        if (digitsOnly.length !== 10) {
          phoneError.textContent = 'Mobile number must be exactly 10 digits.';
        } else {
          const firstDigit = digitsOnly[0];
          phoneError.textContent = 'Mobile number must start with 6, 7, 8, or 9.';
        }
        phoneError.classList.remove('d-none');
        return;
      } else {
        const phoneError = document.getElementById('phone-error');
        phoneError.classList.add('d-none');
      }

      // Validate state
      if (!state) {
        const stateError = document.getElementById('state-error');
        stateError.textContent = 'Please select a state.';
        stateError.classList.remove('d-none');
        return;
      } else {
        const stateError = document.getElementById('state-error');
        stateError.classList.add('d-none');
      }

      // Validate city
      if (!city) {
        const cityError = document.getElementById('city-error');
        cityError.textContent = 'Please select a city.';
        cityError.classList.remove('d-none');
        return;
      } else {
        const cityError = document.getElementById('city-error');
        cityError.classList.add('d-none');
      }

      // All validations passed, submit form
      const formData = new FormData(form);
      const payload = {};
      formData.forEach((v, k) => payload[k] = v);

      fetch('/api/volunteers', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      })
      .then(r => r.json())
      .then(res => {
        if (res.success) {
          alertBox.className = 'alert alert-success';
          alertBox.textContent = 'Thank you for registering as a volunteer. We will contact you soon.';
          alertBox.classList.remove('d-none');
          form.reset();
          // Reset autocomplete lists
          document.getElementById('states-list').innerHTML = '';
          document.getElementById('cities-list').innerHTML = '';
          if (typeof getStatesSuggestions === 'function') {
            document.getElementById('states-list').innerHTML = getStatesSuggestions('').map(s => `<option value="${s}">`).join('');
          }
        } else {
          // Display validation errors from server
          if (res.errors && typeof res.errors === 'object') {
            const firstError = Object.values(res.errors)[0];
            alertBox.textContent = 'Validation error: ' + firstError;
          } else {
            alertBox.textContent = 'Error: ' + (res.message || 'Failed to submit form');
          }
          alertBox.className = 'alert alert-danger';
          alertBox.classList.remove('d-none');
        }
      })
      .catch((err) => {
        alertBox.className = 'alert alert-danger';
        alertBox.textContent = 'Network error: ' + err.message;
        alertBox.classList.remove('d-none');
      });
    });

    // Helper function to create error element if it doesn't exist
    function createErrorElement(id, referenceElement) {
      const errorEl = document.createElement('div');
      errorEl.id = id;
      errorEl.className = 'invalid-feedback d-block d-none';
      referenceElement.parentElement.appendChild(errorEl);
      return errorEl;
    }
  </script>

    </main>

    <footer class="bg-dark text-white mt-5 pt-4 pb-3">
      <div class="container">
        <div class="row">
          <div class="col-md-4 mb-3">
            <h5>About</h5>
            <p class="small">
              <%= (settings && settings.footer_about) || 'A nationwide social and cultural organization dedicated to selfless service, character building, and national integration through thousands of volunteers and grassroots projects.' %>
            </p>
          </div>
          <div class="col-md-4 mb-3">
            <h5>Quick Links</h5>
            <ul class="list-unstyled small">
              <% let quickLinks = []; try { quickLinks = settings && settings.footer_quick_links_json ? JSON.parse(settings.footer_quick_links_json) : []; } catch (e) { quickLinks = []; } %>
              <% if (!quickLinks.length) { %>
                <li><a href="/about" class="text-white text-decoration-none">About Us</a></li>
                <li><a href="/activities" class="text-white text-decoration-none">Activities</a></li>
                <li><a href="/media" class="text-white text-decoration-none">Media</a></li>
                <li><a href="/get-involved" class="text-white text-decoration-none">Volunteer / Donate</a></li>
                <li><a href="/contact" class="text-white text-decoration-none">Contact</a></li>
              <% } else { %>
                <% quickLinks.forEach(function(link) { %>
                  <li><a href="<%= link.url %>" class="text-white text-decoration-none"><%= link.label %></a></li>
                <% }); %>
              <% } %>
            </ul>
          </div>
          <div class="col-md-4 mb-3">
            <h5>Contact</h5>
            <% const footerContact = (settings && settings.footer_contact) || '113, Shivalik Nagar, BHEL, Haridwar, UK, India (249403)\nEmail: aaryawartsevanyaas@gmail.com\nPhone: +91-9253999082, 9253999083'; %>
            <% footerContact.split(/\r?\n/).forEach(function(line) { %>
              <p class="small mb-1"><%= line %></p>
            <% }); %>
          </div>
        </div>
        <div class="text-center small mt-3">
          &copy; <%= new Date().getFullYear() %> <%= (settings && settings.site_name) || 'Aaryawart Seva Nyaas' %>. All rights reserved.
        </div>
      </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/static/js/main.js"></script>
  </body>
</html>
