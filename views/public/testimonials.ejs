<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> - <%= (settings && settings.site_name) || 'Aaryawart Seva Nyaas' %></title>
    <meta name="description" content="Read testimonials from people whose lives have been impacted by <%= (settings && settings.site_name) || 'Aaryawart Seva Nyaas' %>" />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"
    />
    <link rel="stylesheet" href="/static/css/style.css" />
  </head>
  <body>
    <header class="border-bottom bg-light">
      <!-- Desktop Header -->
      <div class="container py-2 py-md-2 d-none d-md-flex flex-wrap justify-content-between align-items-center gap-2">
        <div class="d-flex align-items-center gap-2 gap-md-3 flex-shrink-0 min-w-0">
          <img src="<%= (settings && settings.header_logo_url) || '/static/images/logo.png' %>" alt="Logo" class="logo-img flex-shrink-0" />
          <div class="min-w-0">
            <span class="fw-bold text-primary d-block text-truncate site-name-desktop"><%= (settings && settings.site_name) || 'Aaryawart Seva Nyaas' %></span>
            <small class="text-muted d-none d-sm-inline"><%= (settings && settings.site_tagline) || 'Seva | Shiksha | Sahyog' %></small>
          </div>
        </div>
        <div class="d-flex gap-2 flex-shrink-0">
          <a href="/get-involved" class="btn btn-outline-primary btn-sm">Join Us</a>
          <a href="/get-involved#donate" class="btn btn-primary btn-sm">Donate</a>
        </div>
      </div>

      <!-- Mobile Header -->
      <div class="container py-3 d-md-none">
        <div class="d-flex flex-column align-items-center text-center gap-2">
          <img src="<%= (settings && settings.header_logo_url) || '/static/images/logo.png' %>" alt="Logo" class="logo-img" />
          <div>
            <span class="fw-bold text-primary d-block site-name-mobile"><%= (settings && settings.site_name) || 'Aaryawart Seva Nyaas' %></span>
            <small class="text-muted d-block"><%= (settings && settings.site_tagline) || 'Seva | Shiksha | Sahyog' %></small>
          </div>
        </div>
      </div>

      <!-- Mobile Buttons -->
      <div class="container d-md-none pb-2">
        <div class="d-flex justify-content-center gap-2">
          <a href="/get-involved" class="btn btn-outline-primary btn-sm flex-grow-1 flex-md-grow-0 btn-no-min-width">Join</a>
          <a href="/get-involved#donate" class="btn btn-primary btn-sm flex-grow-1 flex-md-grow-0 btn-no-min-width">Donate</a>
        </div>
      </div>
      <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
          <a class="navbar-brand" href="/">Home</a>
          <button
            class="navbar-toggler"
            type="button"
            data-bs-toggle="collapse"
            data-bs-target="#mainNav"
            aria-controls="mainNav"
            aria-expanded="false"
            aria-label="Toggle navigation"
          >
            <span class="navbar-toggler-icon"></span>
          </button>
          <div class="collapse navbar-collapse" id="mainNav">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
              <li class="nav-item"><a class="nav-link" href="/about">About Us</a></li>
              <li class="nav-item"><a class="nav-link" href="/activities">Activities &amp; Programs</a></li>
              <li class="nav-item"><a class="nav-link" href="/media">Media &amp; Publications</a></li>
              <li class="nav-item"><a class="nav-link" href="/testimonials">Testimonials</a></li>
              <li class="nav-item"><a class="nav-link" href="/get-involved">Get Involved</a></li>
              <li class="nav-item"><a class="nav-link" href="/contact">Contact</a></li>
            </ul>
            <div class="d-flex gap-3 py-2 py-lg-0 justify-content-center justify-content-lg-end flex-wrap">
              <% let socialLinks = []; try { socialLinks = settings && settings.social_links_json ? JSON.parse(settings.social_links_json) : []; } catch (e) { socialLinks = []; } %>
              <% if (!socialLinks.length) { %>
                <a href="https://www.facebook.com/people/Aaryawart-Seva-Nyaas/61585981201970/" class="text-white text-decoration-none" aria-label="Facebook"><i class="bi bi-facebook"></i></a>
                <a href="https://x.com/aaryawartastro" class="text-white text-decoration-none" aria-label="Twitter"><i class="bi bi-twitter-x"></i></a>
                <a href="https://www.instagram.com/aaryawart_seva_nyaas/" class="text-white text-decoration-none" aria-label="Instagram"><i class="bi bi-instagram"></i></a>
                <a href="https://www.youtube.com/@aaryawartastroworld" class="text-white text-decoration-none" aria-label="YouTube"><i class="bi bi-youtube"></i></a>
                <a href="https://linkedin.com" class="text-white text-decoration-none" aria-label="LinkedIn"><i class="bi bi-linkedin"></i></a>
              <% } else { %>
                <% socialLinks.forEach(function(link) { %>
                  <a href="<%= link.url %>" class="text-white text-decoration-none" aria-label="<%= link.id %>"><i class="bi <%= link.icon %>"></i></a>
                <% }); %>
              <% } %>
            </div>
          </div>
        </div>
      </nav>
      <div class="news-ticker bg-warning text-dark">
        <div class="container">
          <div class="ticker-wrapper">
            <span class="fw-bold me-2 ticker-label">Latest:</span>
            <div class="ticker-content">
              <span class="ticker-text">
                <%= (settings && settings.news_ticker_text) || 'Upcoming health camp in rural districts • National youth leadership workshop • Flood relief volunteer deployment • New education centers inaugurated' %>
              </span>
            </div>
          </div>
        </div>
      </div>
    </header>

    <main>
      <section class="py-5">
        <div class="container">
          <h1 class="mb-4">Testimonials</h1>
          <p class="lead mb-5">Read stories from people whose lives have been impacted by our work. We would love to hear your story too!</p>

          <div class="row">
            <div class="col-lg-6">
              <h3 class="mb-4">Share Your Testimonial</h3>
              <div id="testimonial-alert" class="alert d-none" role="alert"></div>
              <form id="testimonial-form" method="post" action="/api/testimonials">
                <div class="mb-3">
                  <label class="form-label">Your Name</label>
                  <input type="text" name="name" class="form-control" required />
                </div>
                <div class="mb-3">
                  <label class="form-label">Your Email</label>
                  <input type="email" name="email" class="form-control" required />
                </div>
                <div class="mb-3">
                  <label class="form-label">Your Message</label>
                  <textarea name="message" class="form-control" rows="5" placeholder="Share your experience and how our organization has impacted your life..." required></textarea>
                </div>
                <button type="submit" class="btn btn-primary">Submit Testimonial</button>
                <small class="d-block mt-2 text-muted">Your testimonial will be reviewed before appearing on our website.</small>
              </form>

              <% if (submitted) { %>
                <div class="alert alert-success mt-3">
                  <i class="bi bi-check-circle"></i> Thank you for your testimonial! It has been submitted for review.
                </div>
              <% } %>
            </div>

            <div class="col-lg-6">
              <h3 class="mb-4">Recent Testimonials</h3>
              <div id="testimonials-container">
                <p class="text-muted">Loading testimonials...</p>
              </div>
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer class="bg-dark text-white py-5 mt-5">
      <div class="container">
        <div class="row">
          <div class="col-md-6 mb-4 mb-md-0">
            <h5 class="mb-3">About Us</h5>
            <p><%= (settings && settings.footer_about) || 'A nationwide social and cultural organization dedicated to selfless service, character building, and national integration.' %></p>
          </div>
          <div class="col-md-6">
            <h5 class="mb-3">Contact</h5>
            <p>
              <% 
                let contactLines = settings && settings.footer_contact ? settings.footer_contact.split('\n') : [];
                if (contactLines.length === 0) {
                  contactLines = ['113, Shivalik Nagar, BHEL, Haridwar, UK, India (249403)', 'Email: aaryawartsevanyaas@gmail.com', 'Phone: +91-9253999082, 9253999083'];
                }
                contactLines.forEach(function(line, i) {
              %>
                <%= i > 0 ? '<br/>' : '' %><%= line.trim() %>
              <% }); %>
            </p>
          </div>
        </div>
        <hr class="my-4" />
        <div class="text-center">
          <p>&copy; 2024 <%= (settings && settings.site_name) || 'Aaryawart Seva Nyaas' %>. All rights reserved.</p>
        </div>
      </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
      document.getElementById('testimonial-form').addEventListener('submit', async function(e) {
        e.preventDefault();
        const alert = document.getElementById('testimonial-alert');
        const formData = new FormData(this);
        
        try {
          const name = formData.get('name');
          const email = formData.get('email');
          const message = formData.get('message');
          
          console.log('[Testimonial Form] Submitting:', { name, email, messageLength: message.length });
          
          const response = await fetch('/api/testimonials', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({ name, email, message }),
          });
          
          console.log('[Testimonial Form] Response status:', response.status);
          
          const result = await response.json();
          console.log('[Testimonial Form] Response body:', result);
          
          if (result.success) {
            alert.className = 'alert alert-success';
            alert.innerHTML = '<i class="bi bi-check-circle"></i> ' + result.message;
            this.reset();
          } else {
            alert.className = 'alert alert-danger';
            alert.innerHTML = '<i class="bi bi-exclamation-circle"></i> ' + (result.message || 'An error occurred. Please try again.');
          }
          alert.classList.remove('d-none');
        } catch (err) {
          console.error('[Testimonial Form] Error:', err);
          alert.className = 'alert alert-danger';
          alert.innerHTML = '<i class="bi bi-exclamation-circle"></i> Network error. Please check your connection and try again.';
          alert.classList.remove('d-none');
        }
      });

      // Load approved testimonials
      async function loadTestimonials() {
        const container = document.getElementById('testimonials-container');
        try {
          const response = await fetch('/api/testimonials');
          const result = await response.json();
          
          if (result.success && result.data.length > 0) {
            container.innerHTML = result.data.map(testimonial => `
              <div class="card mb-3">
                <div class="card-body">
                  <p class="card-text">"${testimonial.message}"</p>
                  <p class="card-text">
                    <strong>${testimonial.name}</strong><br/>
                    <small class="text-muted">${new Date(testimonial.submitted_at).toLocaleDateString()}</small>
                  </p>
                </div>
              </div>
            `).join('');
          } else {
            container.innerHTML = '<p class="text-muted">No testimonials yet. Be the first to share yours!</p>';
          }
        } catch (err) {
          container.innerHTML = '<p class="text-muted">Unable to load testimonials. Please try again later.</p>';
        }
      }

      // Load testimonials on page load
      loadTestimonials();
    </script>
  </body>
</html>
