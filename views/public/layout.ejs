<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> - <%= siteSettings.site_name || 'Charity Organization' %></title>
    <meta name="description" content="<%= siteSettings.site_description || '' %>" />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"
    />
    <link rel="stylesheet" href="/static/css/style.css" />
  </head>
  <body>
    <header class="border-bottom bg-light">
      <div class="container py-2 py-md-2 d-flex flex-wrap justify-content-between align-items-center gap-2">
        <div class="d-flex align-items-center gap-2 gap-md-3 flex-shrink-0 min-w-0">
          <img src="/static/images/logo.png" alt="Logo" class="logo-img flex-shrink-0" />
          <div class="min-w-0">
            <span class="fw-bold text-primary d-block text-truncate" style="font-size: clamp(0.9rem, 3vw, 1rem);"><%= siteSettings.site_name || 'Organization' %></span>
            <small class="text-muted d-none d-sm-inline"><%= siteSettings.site_tagline || '' %></small>
          </div>
        </div>
        <div class="d-none d-md-flex gap-2 flex-shrink-0">
          <a href="/get-involved" class="btn btn-outline-primary btn-sm">Join Us</a>
          <a href="/get-involved#donate" class="btn btn-primary btn-sm">Donate</a>
        </div>
      </div>
      <div class="container d-md-none mt-2 pb-2">
        <div class="d-flex justify-content-center gap-2">
          <a href="/get-involved" class="btn btn-outline-primary btn-sm flex-grow-1 flex-md-grow-0" style="min-width: 0;">Join</a>
          <a href="/get-involved#donate" class="btn btn-primary btn-sm flex-grow-1 flex-md-grow-0" style="min-width: 0;">Donate</a>
        </div>
      </div>
      <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
          <a class="navbar-brand" href="/">Home</a>
          <button
            class="navbar-toggler"
            type="button"
            data-bs-toggle="collapse"
            data-bs-target="#mainNav"
            aria-controls="mainNav"
            aria-expanded="false"
            aria-label="Toggle navigation"
          >
            <span class="navbar-toggler-icon"></span>
          </button>
          <div class="collapse navbar-collapse" id="mainNav">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
              <li class="nav-item"><a class="nav-link" href="/about">About Us</a></li>
              <li class="nav-item"><a class="nav-link" href="/activities">Activities & Programs</a></li>
              <li class="nav-item"><a class="nav-link" href="/media">Media & Publications</a></li>
              <li class="nav-item"><a class="nav-link" href="/get-involved">Get Involved</a></li>
              <li class="nav-item"><a class="nav-link" href="/contact">Contact</a></li>
            </ul>
            <div class="d-flex gap-3 py-2 py-lg-0 justify-content-center justify-content-lg-end flex-wrap">
              <% if (siteSettings.social_facebook) { %>
                <a href="<%= siteSettings.social_facebook %>" class="text-white text-decoration-none" aria-label="Facebook"><i class="bi bi-facebook"></i></a>
              <% } %>
              <% if (siteSettings.social_twitter) { %>
                <a href="<%= siteSettings.social_twitter %>" class="text-white text-decoration-none" aria-label="Twitter"><i class="bi bi-twitter-x"></i></a>
              <% } %>
              <% if (siteSettings.social_instagram) { %>
                <a href="<%= siteSettings.social_instagram %>" class="text-white text-decoration-none" aria-label="Instagram"><i class="bi bi-instagram"></i></a>
              <% } %>
              <% if (siteSettings.social_youtube) { %>
                <a href="<%= siteSettings.social_youtube %>" class="text-white text-decoration-none" aria-label="YouTube"><i class="bi bi-youtube"></i></a>
              <% } %>
              <% if (siteSettings.social_linkedin) { %>
                <a href="<%= siteSettings.social_linkedin %>" class="text-white text-decoration-none" aria-label="LinkedIn"><i class="bi bi-linkedin"></i></a>
              <% } %>
            </div>
          </div>
        </div>
      </nav>
      <div class="news-ticker bg-warning text-dark">
        <div class="container">
          <span class="fw-bold me-2">Latest:</span>
          <marquee behavior="scroll" direction="left">
            Upcoming health camp in rural districts • National youth leadership workshop • Flood relief volunteer deployment • New education centers inaugurated
          </marquee>
        </div>
      </div>
    </header>

    <main>
      <%- body %>
    </main>

    <footer class="bg-dark text-white mt-5 pt-4 pb-3">
      <div class="container">
        <div class="row">
          <div class="col-md-4 mb-3">
            <h5>About</h5>
            <p class="small">
              <%= siteSettings.site_description || 'A nationwide social and cultural organization dedicated to selfless service, character building, and national integration through thousands of volunteers and grassroots projects.' %>
            </p>
          </div>
          <div class="col-md-4 mb-3">
            <h5>Quick Links</h5>
            <ul class="list-unstyled small">
              <li><a href="/about" class="text-white text-decoration-none">About Us</a></li>
              <li><a href="/activities" class="text-white text-decoration-none">Activities</a></li>
              <li><a href="/media" class="text-white text-decoration-none">Media</a></li>
              <li><a href="/get-involved" class="text-white text-decoration-none">Volunteer / Donate</a></li>
              <li><a href="/contact" class="text-white text-decoration-none">Contact</a></li>
            </ul>
          </div>
          <div class="col-md-4 mb-3">
            <h5>Contact</h5>
            <% if (siteSettings.contact_email) { %>
              <p class="small mb-1">Email: <a href="mailto:<%= siteSettings.contact_email %>" class="text-white"><%= siteSettings.contact_email %></a></p>
            <% } %>
            <% if (siteSettings.contact_phone) { %>
              <p class="small mb-1">Phone: <a href="tel:<%= siteSettings.contact_phone %>" class="text-white"><%= siteSettings.contact_phone %></a></p>
            <% } %>
            <% if (siteSettings.office_address) { %>
              <p class="small mb-1"><%= siteSettings.office_address %></p>
            <% } %>
          </div>
        </div>
        <div class="text-center small mt-3">
          <%= siteSettings.footer_text || '© ' + new Date().getFullYear() + ' Organization. All rights reserved.' %>
        </div>
      </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/static/js/main.js"></script>
  </body>
</html>

