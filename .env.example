# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=charity_org

# Razorpay (for donations on Get Involved page)
# Get keys from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# SMTP (optional, for volunteer confirmation emails)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=

# Server
PORT=3000

# Uploads directory: should be an absolute path outside the deployment build folder
UPLOADS_DIR=/absolute/path/to/uploads
